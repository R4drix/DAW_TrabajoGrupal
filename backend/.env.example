# =============================================
# CatagaClub — variables de entorno (PLANTILLA)
# =============================================
# Copia este archivo como `.env` (en la misma carpeta `backend/`) y rellena los
# valores reales. NUNCA subas el `.env` al repo (ya está en .gitignore).

# --- Opción A (recomendada) ---
# Pega aquí la "Connection string" que entrega Supabase en
# Project Settings -> Database -> Connection string -> URI.
# Tiene esta forma:
#   postgres://postgres.xxxx:MIPASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Si Supabase te la entrega como "postgresql://" también funciona.
DATABASE_URL=postgresql://postgres.nfnpdxxsfsmhewyfeavu:Cataga_Club_123@aws-1-us-west-1.pooler.supabase.com:5432/postgres

# --- Opción B (alternativa) ---
# Si prefieres definirlo por partes, rellena estas y deja DATABASE_URL vacío:
PGDATABASE=postgres
PGUSER=postgres.xxxx
PGPASSWORD=
PGHOST=aws-0-us-east-1.pooler.supabase.com
PGPORT=6543

# --- Modo local con SQLite (opcional) ---
# Si quieres ignorar Postgres y volver a SQLite para pruebas rápidas,
# pon esto en 1 y deja DATABASE_URL vacío:
# USE_SQLITE=1
USE_SQLITE=0
