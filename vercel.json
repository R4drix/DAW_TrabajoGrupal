{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend/CatagaClubFrontend && npm install && npm run build -- --configuration production",
  "outputDirectory": "frontend/CatagaClubFrontend/dist/CatagaClubFrontend/browser",
  "installCommand": "echo 'no install at root'",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
